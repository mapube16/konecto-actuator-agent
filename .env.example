OPENAI_API_KEY=
SQLITE_DB_PATH=data/actuators.db
CHROMA_PATH=data/chroma
MEMORY_DB_PATH=data/memory.db
MODEL_NAME=gpt-5-mini
EMBEDDING_MODEL=text-embedding-3-small
RATE_LIMIT=30/minute
GOOGLE_API_KEY=

# Used by scripts/extract_pdf.py (PDF extraction) and the eval LLM-judge (scripts/eval.py).
