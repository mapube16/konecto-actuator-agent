# REQUIRED — the only key needed to run the agent (chat + embeddings, incl. the ingest step).
OPENAI_API_KEY=

SQLITE_DB_PATH=data/actuators.db
CHROMA_PATH=data/chroma
MEMORY_DB_PATH=data/memory.db
MODEL_NAME=gpt-5-mini
EMBEDDING_MODEL=text-embedding-3-small
RATE_LIMIT=30/minute

# OPTIONAL — not needed to run or reproduce the service. Only used by:
#   - scripts/extract_pdf.py (re-extract the PDF; the processed data/actuators.json is already committed)
#   - the eval LLM-judge (scripts/eval.py); without it, judge cases fall back to a non-empty check.
OPENROUTER_API_KEY=
# Optional: override the OpenRouter model used by the eval judge (default openai/gpt-4o-mini)
EVAL_JUDGE_MODEL=openai/gpt-4o-mini
